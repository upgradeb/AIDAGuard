{
  "id": "picoclaw",
  "name": "Pico Claw",
  "version": "1.0.0",
  "description": "Pico Claw agent",
  "author": "Pico Claw Community",
  "categories": ["cli-tool", "openai-compatible"],
  "detect": { "type": "file_exists", "path": "~/.picoclaw/config.json" },
  "config": {
    "path": "~/.picoclaw/config.json",
    "format": "json",
    "endpoint": {
      "read": ["baseUrl", "apiBase", "endpoint"],
      "write": { "baseUrl": "proxyUrl" }
    },
    "model": { "read": ["model"] }
  },
  "custom": false
}
