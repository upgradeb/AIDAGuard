{
  "id": "coffeecli",
  "name": "Coffee CLI",
  "version": "1.0.0",
  "description": "Coffee CLI coding agent",
  "author": "Coffee CLI",
  "categories": ["cli-tool", "openai-compatible"],
  "detect": { "type": "dir_exists", "path": "~/.coffee-cli" },
  "config": {
    "path": "~/.coffee-cli/config.json",
    "format": "json",
    "endpoint": {
      "read": ["baseUrl", "apiBase", "endpoint"],
      "write": { "baseUrl": "proxyUrl" }
    },
    "model": { "read": ["model"] }
  },
  "custom": false
}
